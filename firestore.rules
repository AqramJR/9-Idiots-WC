rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin = your Firebase Auth UID has a document in the `admins` collection.
    // This is registered manually, once, via Firebase Console (Firestore ->
    // admins collection -> add a document whose ID is the admin's UID, found
    // in Authentication -> Users). It intentionally can't be set through the
    // app itself. NOTE: this can no longer be "signed in with password" —
    // every player now signs in with password too (the username/password
    // system), so that check would grant every player admin access.
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Predictions are only allowed once kickoff is within 20 hours — mirrors
    // isPredictionWindowOpen() in src/utils/dateHelpers.ts on the client.
    function isPredictionWindowOpen(matchId) {
      let kickoff = get(/databases/$(database)/documents/matches/$(matchId)).data.kickoff;
      return kickoff > request.time.toMillis()
        && kickoff - request.time.toMillis() <= 72000000; // 20 hours in ms
    }

    // ---------- admins ----------
    // Managed entirely via Firebase Console, never through the app. A user
    // may only check whether THEY THEMSELVES are an admin (their own doc) —
    // never list the collection or write to it.
    match /admins/{uid} {
      allow get: if request.auth != null && request.auth.uid == uid;
      allow list: if false;
      allow write: if false;
    }

    // ---------- users ----------
    // Anyone signed in can read the roster (needed for the public leaderboard).
    // A user may only create/update their own profile document.
    // points / exactPredictions / correctOutcomes are recalculated server-side
    // by the admin recalculation flow, but we still allow the owner to write
    // their own doc so the client can create it on first join.
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ---------- matches ----------
    // Everyone can read matches. Only the admin can create/edit/delete them
    // or enter final scores.
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- predictions ----------
    // A user can only create/edit their own predictions, and only within the
    // prediction window (see isPredictionWindowOpen above). Admin can
    // create/edit ANY prediction, for any player, at any time — e.g. to
    // enter an existing player's pick on their behalf.
    match /predictions/{predictionId} {
      allow read: if true;

      allow create: if isAdmin()
        || (isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.predictedHome is int
          && request.resource.data.predictedAway is int
          && request.resource.data.predictedHome >= 0
          && request.resource.data.predictedAway >= 0
          && isPredictionWindowOpen(request.resource.data.matchId));

      allow update: if isAdmin()
        || (isSignedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.matchId == resource.data.matchId
          && isPredictionWindowOpen(resource.data.matchId));

      allow delete: if isAdmin();
    }
  }
}
